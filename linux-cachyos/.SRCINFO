	depends = glibc
	depends = libelf
	depends = libgcc
	depends = openssl
	depends = pahole
	depends = xxhash
	depends = zlib
	depends = zstd
	depends = linux-cachyos
	depends = clang
	depends = llvm
	depends = lld
	provides = LINUX-HEADERS
